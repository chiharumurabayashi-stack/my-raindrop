{
  "manifest_version": 3,
  "name": "MyRaindrop",
  "version": "1.0",
  "description": "現在のページをMyRaindropに保存",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": [
    "https://firestore.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MyRaindropに保存"
  }
}
